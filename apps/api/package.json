{
  "dependencies": {
    "@dcapx/contracts": "workspace:*",
    "@prisma/client": "^6.19.0",
    "@repo/schema": "workspace:*",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "node-vault": "^0.12.0",
    "otplib": "^12.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.0",
    "prisma": "^6.19.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "supertest": "^7.1.1",
    "@types/supertest": "^6.0.3"
  },
  "name": "api",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:4011": "API_PORT=4011 tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma": "prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:create": "prisma migrate dev --schema prisma/schema.prisma --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:backfill:phase1": "tsx scripts/backfill-phase1.ts",
    "seed:demo": "tsx prisma/seed-demo-bootstrap.ts",
    "test": "vitest run",
    "test:auth": "vitest run test/auth.service.audit.test.ts test/require-auth.audit.test.ts",
    "test:ledger": "vitest run test/ledger.posting.test.ts",
    "test:ledger:lifecycle": "vitest run test/ledger.lifecycle.test.ts",
    "test:ledger:settlement": "vitest run -- ledger.reconciliation.test.ts",
    "test:ledger:execution": "vitest run -- ledger.execution.test.ts",
    "test:ledger:order-state": "vitest run test/ledger.order-state.test.ts",
    "test:ledger:hold-release": "vitest run -- ledger.hold-release.test.ts",
    "test:auth:session-utils": "vitest run test/session-auth.utils.test.ts",
    "test:auth:session-resolution": "vitest run test/session.resolution.test.ts",
    "test:auth:require-auth": "vitest run test/require-auth.comprehensive.test.ts",
    "test:auth:mfa-service": "vitest run test/mfa.service.test.ts",
    "test:auth:vault-bootstrap": "vitest run test/vault-bootstrap.test.ts",
    "test:middleware:ibac": "vitest run test/ibac.middleware.test.ts",
    "test:pass-b": "vitest run test/vault-bootstrap.test.ts test/ibac.middleware.test.ts",
    "test:ledger:phase2-smoke": "vitest run test/ledger.phase2.smoke.test.ts",
    "test:ledger:phase2": "vitest run test/ledger.reconciliation.test.ts test/ledger.execution.test.ts test/ledger.order-state.test.ts test/ledger.hold-release.test.ts test/ledger.phase2.smoke.test.ts",
    "test:routes:trade-cancel": "vitest run test/trade.cancel.guard.test.ts",
    "test:routes:orders": "vitest run test/orders.routes.test.ts",
    "test:routes:reconciliation": "vitest run test/reconciliation.routes.test.ts",
    "test:workers:reconciliation": "vitest run test/reconciliation.worker.test.ts",
    "test:lib:idempotency": "vitest run test/idempotency.lib.test.ts",
    "test:lib:time-in-force": "vitest run test/time-in-force.lib.test.ts",
    "test:ledger:matching-determinism": "vitest run test/ledger.matching-determinism.test.ts",
    "test:ledger:execution-cleanup": "vitest run test/ledger.execution.phase3-cleanup.test.ts",
    "test:matching:submission": "vitest run test/order-submission-unification.test.ts",
    "test:matching:in-memory": "vitest run test/in-memory-matching-engine.test.ts",
    "test:matching:in-memory-settlement": "vitest run test/in-memory-settlement-integration.test.ts",
    "test:matching:serialized-dispatch": "vitest run test/matching-serialized-dispatch.test.ts",
    "test:matching:events": "vitest run test/matching-events.test.ts"
  },
  "type": "commonjs"
}
