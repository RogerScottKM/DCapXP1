{
  "dependencies": {
    "@dcapx/contracts": "workspace:*",
    "@prisma/client": "^6.19.0",
    "@repo/schema": "workspace:*",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "node-vault": "^0.12.0",
    "otplib": "^12.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.0",
    "prisma": "^6.19.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "name": "api",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:4011": "API_PORT=4011 tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma": "prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:create": "prisma migrate dev --schema prisma/schema.prisma --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:backfill:phase1": "tsx scripts/backfill-phase1.ts",
    "seed:demo": "tsx prisma/seed-demo-bootstrap.ts"
  },
  "type": "commonjs"
}
