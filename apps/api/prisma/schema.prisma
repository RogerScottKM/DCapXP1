// apps/api/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// Existing exchange / agent enums (preserved + extended)
// =====================================================
enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  REVOKED
}

enum MandateAction {
  TRADE
  WITHDRAW
  TRANSFER
}

enum MandateStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// ===== Existing core exchange enums =====
enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCEL_PENDING
  CANCELLED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TradeMode {
  PAPER
  LIVE
}

// ===== Existing bank-grade enums =====
enum AssetKind {
  CRYPTO
  FIAT
  FX
  EQUITY
  COMMODITY
  TOKEN
}

enum TwinTier {
  WHALE
  TRADER
  SCALPER
  LEARNER
  NEWBIE
}

enum AgentKind {
  RISK_GUARD
  MARKET_MAKER
  SCALPER
  MEAN_REVERT
  TREND_FOLLOW
  DCA
  NEWS_SENTIMENT
  ARBITRAGE
  PORTFOLIO_MANAGER
}

// =====================================================
// New Phase 1 enums (names chosen to avoid conflicts)
// =====================================================
enum UserStatus {
  INVITED
  REGISTERED
  OTP_VERIFIED
  ACTIVE
  SUSPENDED
  CLOSED
}

enum RoleCode {
  USER
  ADVISOR
  COMPLIANCE
  ADMIN
  AUDITOR
  PARTNER_ADMIN
  PARTNER_OPERATOR
  BANK_OPERATOR
  SYSTEM_AGENT
}

enum OtpPurpose {
  REGISTER
  VERIFY_EMAIL
  VERIFY_PHONE
  LOGIN
  MFA
  RESET_PASSWORD
}

enum OtpChannel {
  EMAIL
  SMS
}

enum MfaFactorType {
  TOTP
}

enum MfaFactorStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum KycCaseStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  NEEDS_INFO
  APPROVED
  REJECTED
  EXPIRED
}

enum KycDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVER_LICENSE
  SELFIE
  PROOF_OF_ADDRESS
  BUSINESS_REGISTRATION
  OTHER
}

enum KycDecisionCode {
  APPROVE
  REJECT
  REQUEST_INFO
}

enum VerificationChannel {
  EMAIL
  SMS
}

enum VerificationPurpose {
  CONTACT_VERIFICATION
  PASSWORD_RESET
  MFA
}

enum PaymentMethodType {
  BANK_ACCOUNT
  STRIPE_CUSTOMER
  PAYPAL_ACCOUNT
  VENMO_ACCOUNT
  OTHER
}

enum PaymentMethodStatus {
  ADDED
  PENDING_VERIFICATION
  VERIFIED
  RESTRICTED
  DISABLED
}

enum WalletType {
  CUSTODIAL
  EXTERNAL
}

enum WalletStatus {
  CREATED
  PENDING_VERIFICATION
  WHITELISTED
  COOLDOWN
  ACTIVE
  FROZEN
  REVOKED
}

enum PartnerOrgType {
  ADVISORY_FIRM
  BANK
  ISSUER
  EMPLOYER
  OTHER
}

enum AssessmentRunStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  SCORED
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AptivioProfileStatus {
  DRAFT
  ASSESSMENT_PENDING
  ACTIVE
  RESTRICTED
  ARCHIVED
}

enum AgentCredentialType {
  PUBLIC_KEY
  API_KEY
}

enum AgentCapabilityTier {
  READ_ONLY
  RECOMMEND_ONLY
  PLAN_ONLY
  EXECUTE_TRADE
}

enum AgentPrincipalType {
  DIGITAL_TWIN
  TRADING_AGENT
  COMPLIANCE_AGENT
  ADVISOR_AGENT
  INTERNAL_MM
}

enum RoleScopeType {
  GLOBAL
  PARTNER_ORG
  CLIENT
  ADVISOR_BOOK
}

enum PartnerOrganizationStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum PartnerReportScope {
  ORG_ONLY
  ASSIGNED_ONLY
  AGGREGATE
}

enum InvitationType {
  CLIENT_ONBOARDING
  ADVISOR_JOIN
  PARTNER_OPERATOR_JOIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AssessmentDefinitionStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum AptivioBand {
  VERY_LOW
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum AptivioSuitabilityStatus {
  INSUFFICIENT_DATA
  PRELIMINARY_MATCH
  NEEDS_ADVISER_REVIEW
  CAUTION
  NOT_ELIGIBLE
}

enum AptivioEligibilityStatus {
  NOT_STARTED
  PENDING
  ELIGIBLE
  REVIEW_REQUIRED
  NOT_ELIGIBLE
}

enum UploadStatus {
  UPLOADING
  UPLOADED
  SCANNING
  AVAILABLE
  QUARANTINED
  REJECTED
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  DATA_PROCESSING
  ELECTRONIC_COMMUNICATION
  APTIVIO_ASSESSMENT_AUTH
  ADVISOR_DATA_SHARING_CONSENT
}

// ======== enum >> referral >> MLM

enum ReferralCodeStatus {
  ACTIVE
  DISABLED
  EXPIRED
}

enum ReferralAttributionStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ReferralApplySource {
  LOGIN
  ONBOARDING
  INVITATION
  REGISTER
  ADMIN
  IMPORT
}

enum RewardUnitType {
  POINTS
  CASH
  TOKEN
  PROFIT_SHARE
  STOCK_OPTION
}

enum RewardEntryType {
  ACCRUAL
  ADJUSTMENT
  REDEMPTION
  REVERSAL
}

enum RewardSourceType {
  REFERRAL_CODE_APPLIED
  REFERRAL_SIGNUP
  REFERRAL_CONTACT_VERIFIED
  REFERRAL_KYC_APPROVED
  REFERRAL_FIRST_FUNDING
  REFERRAL_FIRST_TRADE
  MANUAL_BONUS
  CAMPAIGN_BONUS
}

// =====================================================
// Core exchange (preserved)
// =====================================================
model Market {
  symbol     String      @id
  baseAsset  String
  quoteAsset String
  tickSize   Decimal     @db.Decimal(18, 8)
  lotSize    Decimal     @db.Decimal(18, 8)
  createdAt  DateTime    @default(now())
  orders     Order[]
  // inverse relation for Instrument.market
  instrument Instrument? @relation("MarketInstrument")
}

model Order {
  id        BigInt      @id @default(autoincrement()) @db.BigInt
  symbol    String
  side      OrderSide
  price     Decimal     @db.Decimal(18, 8)
  qty       Decimal     @db.Decimal(18, 8)
  status    OrderStatus @default(OPEN)
  createdAt DateTime    @default(now())
  mode      TradeMode   @default(PAPER)
  // relations
  market    Market      @relation(fields: [symbol], references: [symbol])
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  // trade relations (optional reverse)
  buys      Trade[]     @relation("buyOrder")
  sells     Trade[]     @relation("sellOrder")

  @@index([symbol, mode, side, status, price, createdAt])
  @@index([userId, createdAt])
}

model Trade {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  symbol      String
  price       Decimal   @db.Decimal(18, 8)
  qty         Decimal   @db.Decimal(18, 8)
  createdAt   DateTime  @default(now())
  mode        TradeMode @default(PAPER)
  buyOrderId  BigInt    @db.BigInt
  sellOrderId BigInt    @db.BigInt
  buyOrder    Order     @relation("buyOrder", fields: [buyOrderId], references: [id])
  sellOrder   Order     @relation("sellOrder", fields: [sellOrderId], references: [id])

  @@index([symbol, mode, createdAt])
}

// =====================================================
// Identity / user (merged: old + new)
// =====================================================
model User {
  emailVerifiedAt        DateTime?
  phoneVerifiedAt        DateTime?
  verificationChallenges VerificationChallenge[]
  notificationDeliveries NotificationDelivery[]
  id                     String                    @id @default(cuid())
  email                  String                    @unique
  username               String                    @unique
  passwordHash           String
  totpSecret             String?
  // new Phase 1 fields
  phone                  String?                   @unique
  status                 UserStatus                @default(REGISTERED)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  // existing relations
  kyc                    Kyc?
  balances               Balance[]
  orders                 Order[]
  digitalTwinProfile     DigitalTwinProfile?
  twinAgentAssignments   TwinAgentAssignment[]
  agents                 Agent[]
  // new Phase 1 relations
  profile                UserProfile?
  sessions               Session[]
  otpChallenges          OtpChallenge[]
  mfaFactors             MfaFactor[]
  roles                  RoleAssignment[]
  consents               ConsentRecord[]
  kycCases               KycCase[]
  paymentMethods         PaymentMethod[]
  wallets                Wallet[]
  whitelist              WalletWhitelistEntry[]
  aptivioProfile         AptivioProfile?
  advisorProfile         AdvisorProfile?
  advisorClients         AdvisorClientAssignment[] @relation("AdvisorAssignments")
  clientAdvisors         AdvisorClientAssignment[] @relation("ClientAssignments")
  assessmentRuns         AssessmentRun[]
  passwordResetTokens    PasswordResetToken[]
  verificationCodes      VerificationCode[]

  // =======================================================
  //             Referral >> Future MLM 
  // =======================================================

  referredByCodeInput String?
  acquisitionSource   String?

  referralCodesOwned  ReferralCode[]        @relation("ReferralCodeOwner")
  referralAttribution ReferralAttribution?  @relation("ReferredUser")
  referralsGenerated  ReferralAttribution[] @relation("ReferralReferrer")
  rewardLedgerEntries RewardLedgerEntry[]
  rewardBalances      UserRewardBalance[]

  @@index([status])
}

// ================================

model VerificationCode {
  id          String              @id @default(cuid())
  userId      String
  channel     VerificationChannel
  purpose     VerificationPurpose
  destination String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, channel, expiresAt])
  @@index([destination, purpose, channel, expiresAt])
}

// =====================================================
// Existing house agents (preserved + enriched)
// =====================================================
model Agent {
  id             String                @id @default(cuid())
  userId         String
  name           String
  // new high-level classification
  principalType  AgentPrincipalType?
  capabilityTier AgentCapabilityTier   @default(READ_ONLY)
  // existing strategy/runtime classification
  kind           AgentKind
  version        String                @default("1.0")
  config         Json?
  status         AgentStatus           @default(ACTIVE)
  // Optional: if you later anchor to Aptivio token issuance
  aptivioTokenId String?               @unique
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  assignments    TwinAgentAssignment[]
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  keys           AgentKey[]
  mandates       Mandate[]

  @@index([userId, status])
  @@index([principalType, kind, status])
}

model AgentKey {
  id             String              @id @default(cuid())
  agentId        String
  credentialType AgentCredentialType @default(PUBLIC_KEY)
  // existing public-key path
  publicKeyPem   String?
  // optional API-key path
  keyPrefix      String?
  keyHash        String?             @unique
  createdAt      DateTime            @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  agent          Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([agentId, credentialType])
}

model Mandate {
  id                String         @id @default(cuid())
  agentId           String
  status            MandateStatus  @default(ACTIVE)
  action            MandateAction
  market            String? // null = any market
  // limits stored in integer quantums aligned with ledger
  maxNotionalPerDay BigInt         @default(0)
  maxOrdersPerDay   Int            @default(0)
  notBefore         DateTime       @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  // flexible policy bag: maxQty, tif allowlist, postOnly, maxSlippageBps, priceBandBps, etc
  constraints       Json?
  // optional: hash of external signed capability token
  mandateJwtHash    String?        @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  agent             Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  usage             MandateUsage[]

  @@index([agentId, status])
  @@index([action, market])
}

model MandateUsage {
  id           String   @id @default(cuid())
  mandateId    String
  day          DateTime // normalized to UTC midnight
  notionalUsed BigInt   @default(0)
  ordersPlaced Int      @default(0)
  mandate      Mandate  @relation(fields: [mandateId], references: [id], onDelete: Cascade)

  @@unique([mandateId, day])
  @@index([day])
}

// Replay protection (DB version; later may move to Redis TTL)
model RequestNonce {
  id        String   @id @default(cuid())
  agentId   String
  nonce     String
  tsMs      BigInt
  createdAt DateTime @default(now())

  @@unique([agentId, nonce])
  @@index([createdAt])
}

// =====================================================
// Existing summary KYC + balances (preserved)
// =====================================================
model Kyc {
  id        Int       @id @default(autoincrement())
  userId    String    @unique
  legalName String
  country   String
  dob       DateTime
  docType   String
  docHash   String
  status    KycStatus @default(PENDING)
  riskScore Decimal   @default(0) @db.Decimal(38, 18)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Balance {
  id     Int       @id @default(autoincrement())
  userId String
  asset  String
  amount Decimal   @default(0) @db.Decimal(38, 18)
  mode   TradeMode @default(PAPER)
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mode, asset])
  @@index([userId, mode])
}

// =====================================================
// Existing asset / instrument catalog (preserved)
// =====================================================
model Asset {
  id               String       @id @default(cuid())
  code             String       @unique // BTC, USD, XAU, RVAI
  kind             AssetKind
  venue            String? // BINANCE, COINBASE, OANDA, NASDAQ
  country          String?
  createdAt        DateTime     @default(now())
  issuerControlled Boolean      @default(false)
  baseInstruments  Instrument[] @relation("baseAsset")
  quoteInstruments Instrument[] @relation("quoteAsset")
}

model Instrument {
  id            String   @id @default(cuid())
  displaySymbol String   @unique // BTC-USD, RVAI-USD, XAU-USD
  sourceSymbol  String? // BINANCE:BTCUSDT, OANDA:XAU_USD, NASDAQ:AAPL
  baseAssetId   String
  quoteAssetId  String
  // link to current Market.symbol if you want
  legacySymbol  String?  @unique
  createdAt     DateTime @default(now())
  baseAsset     Asset    @relation("baseAsset", fields: [baseAssetId], references: [id])
  quoteAsset    Asset    @relation("quoteAsset", fields: [quoteAssetId], references: [id])
  market        Market?  @relation("MarketInstrument", fields: [legacySymbol], references: [symbol])
}

// =====================================================
// Existing digital twin trading profile (preserved)
// =====================================================
model DigitalTwinProfile {
  id               Int      @id @default(autoincrement())
  userId           String   @unique
  tier             TwinTier
  // trading personality knobs
  riskPct          Decimal  @default(0.01) @db.Decimal(10, 6)
  maxOrdersPerDay  Int      @default(50)
  preferredSymbols String[] @default([])
  // full plan as JSON
  plan             Json
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwinAgentAssignment {
  id        Int      @id @default(autoincrement())
  userId    String
  agentId   String
  role      String // "primary", "risk", "copilot"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId, role])
  @@index([userId])
  @@index([agentId])
}

// =====================================================
// New Phase 1 identity / onboarding
// =====================================================
model UserProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  firstName     String
  lastName      String
  fullName      String?
  dateOfBirth   DateTime?
  country       String?
  residency     String?
  nationality   String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  employerName  String?
  sourceChannel String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  mfaMethod        String?
  mfaVerifiedAt    DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, mfaVerifiedAt])
}

model OtpChallenge {
  id           String     @id @default(cuid())
  userId       String?
  purpose      OtpPurpose
  channel      OtpChannel
  target       String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int        @default(0)
  createdAt    DateTime   @default(now())
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([target, purpose, expiresAt])
}

model MfaFactor {
  id              String          @id @default(cuid())
  userId          String
  type            MfaFactorType
  status          MfaFactorStatus @default(PENDING)
  label           String?
  secretEncrypted String
  activatedAt     DateTime?
  revokedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model RoleAssignment {
  id               String   @id @default(cuid())
  userId           String
  roleCode         RoleCode
  // Keep String for the first migration to avoid enum-cast failures on existing rows.
  scopeType        String?
  scopeId          String?
  assignedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Keep indexes only for now. Add uniqueness in a later migration after dedup/backfill.
  @@index([userId, roleCode])
  @@index([roleCode, scopeType, scopeId])
}

model ConsentRecord {
  id          String    @id @default(cuid())
  userId      String
  // Keep String for the first migration to avoid enum-cast failures on existing rows.
  consentType String
  version     String
  acceptedAt  DateTime  @default(now())
  revokedAt   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType, version])
  @@index([userId, consentType, revokedAt])
  @@index([userId, acceptedAt])
}

// =====================================================
// New richer KYC workflow (coexists with legacy Kyc)
// =====================================================
model KycCase {
  id             String            @id @default(cuid())
  userId         String
  status         KycCaseStatus     @default(NOT_STARTED)
  providerRef    String?
  notes          String?
  startedAt      DateTime          @default(now())
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewerUserId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents      KycDocument[]
  decisions      KycDecision[]
  screenings     ScreeningResult[]

  @@index([userId, status])
}

model KycDocument {
  id           String          @id @default(cuid())
  kycCaseId    String
  docType      KycDocumentType
  fileKey      String
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  uploadStatus UploadStatus    @default(UPLOADED)
  uploadedAt   DateTime        @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt
  metadata     Json?

  kycCase KycCase @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)

  @@index([kycCaseId, docType])
  @@index([kycCaseId, uploadStatus])
}

model KycDecision {
  id             String          @id @default(cuid())
  kycCaseId      String
  decision       KycDecisionCode
  reasonCode     String?
  notes          String?
  reviewerUserId String
  createdAt      DateTime        @default(now())
  kycCase        KycCase         @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)

  @@index([kycCaseId, createdAt])
}

model ScreeningResult {
  id            String   @id @default(cuid())
  kycCaseId     String
  screeningType String
  result        String
  score         Decimal? @db.Decimal(10, 4)
  payload       Json?
  createdAt     DateTime @default(now())
  kycCase       KycCase  @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)

  @@index([kycCaseId, screeningType])
}

// =====================================================
// Payments / bank methods / wallets
// =====================================================
model PaymentMethod {
  id          String              @id @default(cuid())
  userId      String
  type        PaymentMethodType
  status      PaymentMethodStatus @default(ADDED)
  label       String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount?

  @@index([userId, status, type])
}

model BankAccount {
  id                  String        @id @default(cuid())
  paymentMethodId     String        @unique
  accountHolderName   String
  bankName            String
  country             String?
  currency            String?
  maskedAccountNumber String?
  maskedRoutingNumber String?
  ibanMasked          String?
  swiftBicMasked      String?
  verifiedAt          DateTime?
  metadata            Json?
  paymentMethod       PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
}

model Wallet {
  id          String       @id @default(cuid())
  userId      String
  type        WalletType
  status      WalletStatus @default(CREATED)
  chain       String?
  address     String?
  label       String?
  isCustodial Boolean      @default(false)
  verifiedAt  DateTime?
  activatedAt DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
}

model WalletWhitelistEntry {
  id         String       @id @default(cuid())
  userId     String
  chain      String
  address    String
  label      String?
  status     WalletStatus @default(PENDING_VERIFICATION)
  approvedAt DateTime?
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chain, address])
  @@index([userId, status])
}

// =====================================================
// Partners / advisors
// =====================================================
model PartnerOrganization {
  id                   String                    @id @default(cuid())
  name                 String
  type                 PartnerOrgType
  country              String?
  metadata             Json?
  status               PartnerOrganizationStatus @default(PENDING)
  channelCode          String?                   @unique
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  brandingLogoUrl      String?
  brandingPrimaryColor String?
  reportScope          PartnerReportScope        @default(ORG_ONLY)
  onboardingEnabled    Boolean                   @default(true)
  inviteEnabled        Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  advisors AdvisorProfile[]

  @@index([type, country])
  @@index([status])
}

model AdvisorProfile {
  id             String               @id @default(cuid())
  userId         String               @unique
  organizationId String?
  licenseNumber  String?
  status         String?
  specialties    Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   PartnerOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
}

model AdvisorClientAssignment {
  id            String   @id @default(cuid())
  advisorUserId String
  clientUserId  String
  status        String
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  advisor       User     @relation("AdvisorAssignments", fields: [advisorUserId], references: [id], onDelete: Cascade)
  client        User     @relation("ClientAssignments", fields: [clientUserId], references: [id], onDelete: Cascade)

  @@unique([advisorUserId, clientUserId])
  @@index([clientUserId, status])
}

// =====================================================
// Invitation
// =====================================================

model Invitation {
  id                    String           @id @default(cuid())
  tokenHash             String           @unique
  email                 String
  invitationType        InvitationType
  targetRoleCode        String
  invitedByUserId       String
  partnerOrganizationId String?
  advisorUserId         String?
  status                InvitationStatus @default(PENDING)
  expiresAt             DateTime
  acceptedAt            DateTime?
  acceptedUserId        String?
  metadata              Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @default(now()) @updatedAt

  @@index([email, status])
  @@index([partnerOrganizationId, status])
  @@index([advisorUserId, status])
}

// =====================================================
// Aptivio catalog / profiles / identity
// =====================================================
model AptitudeDefinition {
  id         String                    @id @default(cuid())
  slug       String                    @unique
  name       String
  category   String
  orderIndex Int
  isActive   Boolean                   @default(true)
  createdAt  DateTime                  @default(now())
  scores     AssessmentAptitudeScore[]

  @@index([category, orderIndex])
}

model AptivioProfile {
  id                           String                    @id @default(cuid())
  userId                       String                    @unique
  status                       AptivioProfileStatus      @default(DRAFT)
  score                        Int?
  aptitudeVector               Json?
  twinJson                     Json?
  skillPassportJson            Json?
  professionalismJson          Json?
  trajectoryJson               Json?
  riskProfileJson              Json?
  version                      String                    @default("v1.0.0")
  lastAssessedAt               DateTime?
  latestAssessmentRunId        String?
  latestAssessmentCode         String?
  latestAssessmentVersion      Int?
  assessedAt                   DateTime?
  confidenceLevel              String?
  overallReadinessScore        Int?
  riskBand                     AptivioBand?
  lossCapacityBand             AptivioBand?
  liquidityNeedBand            AptivioBand?
  timeHorizonBand              AptivioBand?
  knowledgeExperienceBand      AptivioBand?
  behaviouralStabilityBand     AptivioBand?
  suitabilityStatus            AptivioSuitabilityStatus?
  suitabilityRationaleCodes    Json?
  aptivioIdEligibilityStatus   AptivioEligibilityStatus?
  digitalTwinEligibilityStatus AptivioEligibilityStatus?
  flagsJson                    Json?
  promptsJson                  Json?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments AssessmentRun[]
  aptivioId   AptivioIdentity?
}

model AssessmentDefinition {
  id                String                     @id @default(cuid())
  code              String
  version           Int
  title             String
  status            AssessmentDefinitionStatus @default(DRAFT)
  schemaJson        Json
  scoringConfigJson Json
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  runs AssessmentRun[]

  @@unique([code, version])
  @@index([code, status])
}

model AssessmentRun {
  id                   String              @id @default(cuid())
  userId               String
  aptivioProfileId     String
  definitionId         String?
  assessmentType       String
  status               AssessmentRunStatus @default(PENDING)
  rawResultJson        Json?
  normalizedJson       Json?
  normalizedResultJson Json?
  clientSummaryJson    Json?
  advisorSummaryJson   Json?
  startedAt            DateTime            @default(now())
  completedAt          DateTime?
  submittedAt          DateTime?
  scoredAt             DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @default(now()) @updatedAt

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aptivioProfile AptivioProfile            @relation(fields: [aptivioProfileId], references: [id], onDelete: Cascade)
  definition     AssessmentDefinition?     @relation(fields: [definitionId], references: [id], onDelete: SetNull)
  scores         AssessmentAptitudeScore[]

  @@index([aptivioProfileId, status, createdAt])
  @@index([userId, createdAt])
  @@index([definitionId, status])
}

model AssessmentAptitudeScore {
  id                   String             @id @default(cuid())
  assessmentRunId      String
  aptitudeDefinitionId String
  score                Int
  confidence           Decimal?           @db.Decimal(5, 4)
  weightForRole        Decimal?           @db.Decimal(5, 4)
  lastAssessedAt       DateTime?
  sourcesJson          Json?
  assessmentRun        AssessmentRun      @relation(fields: [assessmentRunId], references: [id], onDelete: Cascade)
  aptitudeDefinition   AptitudeDefinition @relation(fields: [aptitudeDefinitionId], references: [id], onDelete: Restrict)

  @@unique([assessmentRunId, aptitudeDefinitionId])
  @@index([aptitudeDefinitionId])
}

model AptivioIdentity {
  id                    String         @id @default(cuid())
  aptivioProfileId      String         @unique
  passportNumber        String         @unique
  status                String
  issuedAt              DateTime       @default(now())
  claimsJson            Json?
  tokenEntitlementsJson Json?
  aptivioProfile        AptivioProfile @relation(fields: [aptivioProfileId], references: [id], onDelete: Cascade)
}

// =====================================================
// Audit log
// =====================================================
model AuditEvent {
  id           String   @id @default(cuid())
  actorType    String
  actorId      String?
  subjectType  String?
  subjectId    String?
  action       String
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorType, actorId])
  @@index([resourceType, resourceId])
  @@index([action, createdAt])
}

// ============================================================
//            Password Reset
// ============================================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// ==============================================================
//               Referral >> MLM >> Reward Points
// ==============================================================

model ReferralCode {
  id           String             @id @default(cuid())
  code         String             @unique
  ownerUserId  String
  status       ReferralCodeStatus @default(ACTIVE)
  campaignKey  String?
  communityKey String?
  regionKey    String?
  metadata     Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @default(now()) @updatedAt

  owner        User                  @relation("ReferralCodeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  attributions ReferralAttribution[]

  @@index([ownerUserId, status])
  @@index([campaignKey, status])
  @@index([communityKey, status])
  @@index([regionKey, status])
}

model ReferralAttribution {
  id              String                    @id @default(cuid())
  referredUserId  String                    @unique
  referralCodeId  String
  referrerUserId  String
  status          ReferralAttributionStatus @default(PENDING)
  applySource     ReferralApplySource?
  attributedAt    DateTime                  @default(now())
  confirmedAt     DateTime?
  communityKey    String?
  regionKey       String?
  lineageSnapshot Json?
  metadata        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @default(now()) @updatedAt

  referredUser  User                @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referralCode  ReferralCode        @relation(fields: [referralCodeId], references: [id], onDelete: Restrict)
  referrer      User                @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Restrict)
  rewardEntries RewardLedgerEntry[]

  @@index([referrerUserId, status])
  @@index([referralCodeId, status])
  @@index([communityKey, status])
  @@index([regionKey, status])
}

model RewardLedgerEntry {
  id            String           @id @default(cuid())
  userId        String
  attributionId String?
  unitType      RewardUnitType
  entryType     RewardEntryType
  sourceType    RewardSourceType
  amount        Decimal          @db.Decimal(18, 4)
  currencyCode  String?
  description   String?
  effectiveAt   DateTime         @default(now())
  metadata      Json?
  createdAt     DateTime         @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribution ReferralAttribution? @relation(fields: [attributionId], references: [id], onDelete: SetNull)

  @@index([userId, unitType, effectiveAt])
  @@index([attributionId, sourceType])
}

model UserRewardBalance {
  id        String         @id @default(cuid())
  userId    String
  unitType  RewardUnitType
  balance   Decimal        @db.Decimal(18, 4)
  updatedAt DateTime       @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, unitType])
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  LOCKED
  CANCELLED
}

model VerificationChallenge {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel           VerificationChannel
  purpose           VerificationPurpose
  destinationMasked String
  destinationHash   String
  codeHash          String
  expiresAt         DateTime
  consumedAt        DateTime?
  attemptCount      Int                 @default(0)
  maxAttempts       Int                 @default(5)
  status            VerificationStatus  @default(PENDING)
  providerMessageId String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId, channel, purpose, status])
  @@index([destinationHash, purpose, status])
}

model NotificationDelivery {
  id                String              @id @default(cuid())
  userId            String?
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel           VerificationChannel
  templateKey       String
  provider          String
  destinationMasked String
  providerMessageId String?
  status            String
  errorCode         String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId, channel, templateKey, status])
}

model MfaRecoveryCode {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String    @unique
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt])
}

enum LedgerAccountOwnerType {
  SYSTEM
  USER
}

enum LedgerAccountType {
  USER_AVAILABLE
  USER_HELD
  EXCHANGE_INVENTORY
  FEE_REVENUE
  TREASURY
  SUSPENSE
}

enum LedgerTransactionStatus {
  POSTED
  VOIDED
}

enum LedgerPostingSide {
  DEBIT
  CREDIT
}

model LedgerAccount {
  id          String                 @id @default(cuid())
  ownerType   LedgerAccountOwnerType
  ownerRef    String
  assetCode   String
  mode        TradeMode
  accountType LedgerAccountType
  status      String                 @default("ACTIVE")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @default(now()) @updatedAt
  postings    LedgerPosting[]

  @@unique([ownerType, ownerRef, assetCode, mode, accountType])
  @@index([assetCode, mode, accountType])
  @@index([ownerType, ownerRef, mode])
}

model LedgerTransaction {
  id            String                  @id @default(cuid())
  referenceType String?
  referenceId   String?
  description   String?
  status        LedgerTransactionStatus @default(POSTED)
  metadata      Json?
  createdAt     DateTime                @default(now())
  postings      LedgerPosting[]

  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model LedgerPosting {
  id            String            @id @default(cuid())
  transactionId String
  accountId     String
  assetCode     String
  side          LedgerPostingSide
  amount        Decimal           @db.Decimal(30, 10)
  createdAt     DateTime          @default(now())
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account       LedgerAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([accountId])
  @@index([assetCode, createdAt])
}

