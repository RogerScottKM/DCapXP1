/* ==================== PHASE 1 DELTA (appended cleanly) ==================== */
enum RoleScopeType {
  GLOBAL
  PARTNER_ORG
  CLIENT
  ADVISOR_BOOK
}
enum PartnerOrganizationStatus {
  PENDING
  ACTIVE
  INACTIVE
}
enum PartnerReportScope {
  ORG_ONLY
  ASSIGNED_ONLY
  AGGREGATE
}
enum InvitationType {
  CLIENT_ONBOARDING
  ADVISOR_JOIN
  PARTNER_OPERATOR_JOIN
}
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}
enum AssessmentDefinitionStatus {
  DRAFT
  ACTIVE
  RETIRED
}
enum AssessmentRunStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  SCORED
  FAILED
}
enum AptivioBand {
  VERY_LOW
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}
enum AptivioSuitabilityStatus {
  INSUFFICIENT_DATA
  PRELIMINARY_MATCH
  NEEDS_ADVISER_REVIEW
  CAUTION
  NOT_ELIGIBLE
}
enum AptivioEligibilityStatus {
  NOT_STARTED
  PENDING
  ELIGIBLE
  REVIEW_REQUIRED
  NOT_ELIGIBLE
}
enum UploadStatus {
  UPLOADING
  UPLOADED
  SCANNING
  AVAILABLE
  QUARANTINED
  REJECTED
}
enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  DATA_PROCESSING
  ELECTRONIC_COMMUNICATION
  APTIVIO_ASSESSMENT_AUTH
  ADVISOR_DATA_SHARING_CONSENT
}

model Invitation {
  id String @id @default(cuid())
  tokenHash String @unique
  email String
  invitationType InvitationType
  targetRoleCode String
  invitedByUserId String
  partnerOrganizationId String?
  advisorUserId String?
  status InvitationStatus @default(PENDING)
  expiresAt DateTime
  acceptedAt DateTime?
  acceptedUserId String?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([email, status])
  @@index([partnerOrganizationId, status])
  @@index([advisorUserId, status])
}

model AssessmentDefinition {
  id String @id @default(cuid())
  code String
  version Int
  title String
  status AssessmentDefinitionStatus @default(DRAFT)
  schemaJson Json
  scoringConfigJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([code, version])
  @@index([code, status])
}

model AssessmentRun {
  id String @id @default(cuid())
  userId String
  definitionId String
  status AssessmentRunStatus @default(NOT_STARTED)
  answersJson Json?
  rawResultJson Json?
  normalizedResultJson Json?
  clientSummaryJson Json?
  advisorSummaryJson Json?
  startedAt DateTime @default(now())
  submittedAt DateTime?
  scoredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, createdAt])
  @@index([definitionId, status])
}

model PartnerOrganization {
  id String @id @default(cuid())
  name String
  type String
  country String?
  metadata Json?
  status PartnerOrganizationStatus @default(PENDING)
  channelCode String? @unique
  contactName String?
  contactEmail String?
  contactPhone String?
  brandingLogoUrl String?
  brandingPrimaryColor String?
  reportScope PartnerReportScope @default(ORG_ONLY)
  onboardingEnabled Boolean @default(true)
  inviteEnabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AptivioProfile {
  id String @id @default(cuid())
  userId String @unique
  status String
  latestAssessmentRunId String?
  latestAssessmentCode String?
  latestAssessmentVersion Int?
  assessedAt DateTime?
  confidenceLevel String?
  overallReadinessScore Int?
  riskBand AptivioBand?
  lossCapacityBand AptivioBand?
  liquidityNeedBand AptivioBand?
  timeHorizonBand AptivioBand?
  knowledgeExperienceBand AptivioBand?
  behaviouralStabilityBand AptivioBand?
  suitabilityStatus AptivioSuitabilityStatus?
  suitabilityRationaleCodes Json?
  aptivioIdEligibilityStatus AptivioEligibilityStatus?
  digitalTwinEligibilityStatus AptivioEligibilityStatus?
  flagsJson Json?
  promptsJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsentRecord {
  id String @id @default(cuid())
  userId String
  consentType ConsentType
  version String
  acceptedAt DateTime @default(now())
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, consentType, revokedAt])
  @@index([userId, acceptedAt])
}

model KycDocument {
  id String @id @default(cuid())
  kycCaseId String
  documentType String
  fileKey String
  originalFileName String
  mimeType String
  sizeBytes Int
  uploadStatus UploadStatus @default(UPLOADED)
  uploadedAt DateTime @default(now())
  reviewedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([kycCaseId, uploadStatus])
}

