{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@dcapx/contracts": ["../../packages/contracts/src/index.ts"],
      "@dcapx/contracts/*": ["../../packages/contracts/src/*"]
    }
  },
  "include": ["src", "src/**/*.ts", "src/**/*.d.ts"]
}
