{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "rootDir": "src",
    "noEmit": false
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
